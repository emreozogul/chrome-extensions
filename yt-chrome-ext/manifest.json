{
    "manifest_version": 3,
    "name": "YouTube Moments Saver",
    "version": "1.0.0",
    "description": "Save timestamps and notes for YouTube videos",
    "permissions": [
        "storage",
        "tabs",
        "contextMenus"
    ],
    "host_permissions": [
        "https://www.youtube.com/*",
        "https://youtube.com/*"
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "assets/icon16.png",
            "64": "assets/icon64.png",
            "128": "assets/icon128.png"
        }
    },
    "icons": {
        "16": "assets/icon16.png",
        "64": "assets/icon64.png",
        "128": "assets/icon128.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.youtube.com/*",
                "https://youtube.com/*"
            ],
            "js": [
                "content/content.js"
            ]
        }
    ],
    "background": {
        "service_worker": "background/background.js"
    }
}