{
    "name": "youtube-moments-saver",
    "version": "1.0.0",
    "description": "Chrome extension to save timestamps and notes for YouTube videos",
    "scripts": {
        "setup": "npm install",
        "postinstall": "npm i -D @types/chrome @types/react @types/react-dom @types/uuid",
        "build": "webpack --mode production",
        "dev": "webpack --mode development --watch",
        "package": "zip -r youtube-moments-saver.zip dist/*"
    },
    "dependencies": {
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "tailwindcss": "^3.3.3",
        "uuid": "^9.0.0"
    },
    "devDependencies": {
        "@types/chrome": "^0.0.246",
        "@types/react": "^18.3.18",
        "@types/react-dom": "^18.3.5",
        "@types/uuid": "^9.0.8",
        "autoprefixer": "^10.4.15",
        "copy-webpack-plugin": "^11.0.0",
        "css-loader": "^6.8.1",
        "html-webpack-plugin": "^5.5.3",
        "postcss": "^8.4.29",
        "postcss-loader": "^7.3.3",
        "sharp": "^0.32.5",
        "style-loader": "^3.3.3",
        "ts-loader": "^9.4.4",
        "typescript": "^5.2.2",
        "webpack": "^5.88.2",
        "webpack-cli": "^5.1.4"
    }
}